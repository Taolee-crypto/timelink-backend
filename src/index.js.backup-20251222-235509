// src/index.js - Deconomic Phase 1 핵심 기능
export default {
  async fetch(request, env, ctx) {
    const url = new URL(request.url);
    const method = request.method;
    
    // CORS 헤더
    const corsHeaders = {
      'Access-Control-Allow-Origin': '*',
      'Access-Control-Allow-Methods': 'GET, POST, OPTIONS',
      'Access-Control-Allow-Headers': 'Content-Type',
      'Content-Type': 'application/json'
    };
    
    // OPTIONS 요청 처리
    if (method === 'OPTIONS') {
      return new Response(null, { headers: corsHeaders });
    }
    
    // ========== API 라우팅 ==========
    
    // 1. 헬스 체크 & KV 상태 확인
    if (url.pathname === '/health' || url.pathname === '/') {
      try {
        // KV 연결 테스트
        const testKey = `deconomic:health:${Date.now()}`;
        await env.USERS.put(testKey, JSON.stringify({ 
          check: 'ok', 
          time: new Date().toISOString() 
        }));
        
        const testData = await env.USERS.get(testKey, 'json');
        
        return Response.json({
          service: 'Deconomic API',
          status: '✅ HEALTHY',
          phase: '1 - KV Connected',
          timestamp: new Date().toISOString(),
          kv: {
            users: !!env.USERS,
            sessions: !!env.SESSIONS,
            test: 'passed'
          },
          endpoints: {
            health: 'GET /health',
            signup: 'POST /api/auth/signup',
            asset_create: 'POST /api/assets',
            tl_charge: 'POST /api/tl/charge'
          }
        }, { headers: corsHeaders });
        
      } catch (error) {
        return Response.json({
          service: 'Deconomic API',
          status: '⚠️ DEGRADED',
          error: error.message,
          kv: {
            users: !!env.USERS,
            sessions: !!env.SESSIONS
          },
          note: 'KV 연결 실패, 메모리 모드로 전환'
        }, { headers: corsHeaders, status: 200 });
      }
    }
    
    // 2. Deconomic 사용자 등록 (가장 간단한 버전)
    if (url.pathname === '/api/auth/signup' && method === 'POST') {
      try {
        const { email, username } = await request.json();
        
        if (!email || !username) {
          return Response.json({ 
            error: '이메일과 사용자명이 필요합니다' 
          }, { status: 400, headers: corsHeaders });
        }
        
        // 기존 사용자 확인
        const existingUser = await env.USERS.get(`user:${email}`, 'json');
        if (existingUser) {
          return Response.json({
            success: false,
            error: '이미 존재하는 사용자입니다',
            user: existingUser
          }, { status: 409, headers: corsHeaders });
        }
        
        // 새 사용자 생성
        const userId = `deco_${Date.now()}`;
        const newUser = {
          id: userId,
          email,
          username,
          tlBalance: 1000, // 가입 보너스 1,000 TL
          userType: 'consumer',
          createdAt: new Date().toISOString(),
          updatedAt: new Date().toISOString(),
          assets: []
        };
        
        // KV에 저장
        await env.USERS.put(`user:${email}`, JSON.stringify(newUser));
        
        // 세션 생성
        const sessionId = `sess_${Date.now()}`;
        const session = {
          sessionId,
          userId,
          email,
          createdAt: new Date().toISOString(),
          expiresAt: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString()
        };
        
        await env.SESSIONS.put(sessionId, JSON.stringify(session));
        
        return Response.json({
          success: true,
          message: '🎉 Deconomic 가입 완료!',
          user: {
            id: newUser.id,
            email: newUser.email,
            username: newUser.username,
            tlBalance: newUser.tlBalance
          },
          sessionId,
          welcomeBonus: '1,000 TL이 지급되었습니다!'
        }, { headers: corsHeaders });
        
      } catch (error) {
        return Response.json({
          success: false,
          error: error.message
        }, { status: 500, headers: corsHeaders });
      }
    }
    
    // 3. 디지털 자산 생성 (STUDIO 기능)
    if (url.pathname === '/api/assets' && method === 'POST') {
      try {
        const assetData = await request.json();
        const { title, fileType, uploaderEmail } = assetData;
        
        if (!title || !fileType || !uploaderEmail) {
          return Response.json({
            error: '제목, 파일타입, 업로더 이메일이 필요합니다'
          }, { status: 400, headers: corsHeaders });
        }
        
        // 사용자 확인
        const user = await env.USERS.get(`user:${uploaderEmail}`, 'json');
        if (!user) {
          return Response.json({
            error: '사용자를 찾을 수 없습니다. 먼저 가입해주세요.'
          }, { status: 404, headers: corsHeaders });
        }
        
        // TL 타입 결정
        const tlTypeMap = {
          'audio': 'TL3',
          'video': 'TL4',
          'document': 'TLD',
          'image': 'TLI',
          'ebook': 'TLE'
        };
        
        const tlType = tlTypeMap[fileType.toLowerCase()] || 'TL0';
        
        // 자산 생성
        const assetId = `asset_${Date.now()}`;
        const asset = {
          id: assetId,
          title,
          fileType,
          tlType,
          uploaderEmail,
          uploaderId: user.id,
          tlCharged: 0,
          tlConsumed: 0,
          tlRemaining: 0,
          isActive: false,
          earnings: 0,
          views: 0,
          createdAt: new Date().toISOString(),
          status: 'TL0 상태 - TL 충전 필요'
        };
        
        // KV에 저장
        await env.USERS.put(`asset:${assetId}`, JSON.stringify(asset));
        
        // 사용자의 자산 목록에 추가
        user.assets = user.assets || [];
        user.assets.push(assetId);
        await env.USERS.put(`user:${uploaderEmail}`, JSON.stringify(user));
        
        return Response.json({
          success: true,
          message: '✅ 디지털 자산 생성 완료!',
          asset: {
            id: asset.id,
            title: asset.title,
            fileType: asset.fileType,
            tlType: asset.tlType,
            status: asset.status,
            nextStep: 'TL 충전 필요'
          },
          userTlBalance: user.tlBalance
        }, { headers: corsHeaders });
        
      } catch (error) {
        return Response.json({
          success: false,
          error: error.message
        }, { status: 500, headers: corsHeaders });
      }
    }
    
    // 4. TL 충전 API
    if (url.pathname === '/api/tl/charge' && method === 'POST') {
      try {
        const { email, amount, assetId } = await request.json();
        
        if (!email || !amount) {
          return Response.json({
            error: '이메일과 충전량이 필요합니다'
          }, { status: 400, headers: corsHeaders });
        }
        
        // 사용자 확인
        const user = await env.USERS.get(`user:${email}`, 'json');
        if (!user) {
          return Response.json({
            error: '사용자를 찾을 수 없습니다'
          }, { status: 404, headers: corsHeaders });
        }
        
        // TL 잔액 업데이트
        user.tlBalance = (user.tlBalance || 0) + parseInt(amount);
        user.updatedAt = new Date().toISOString();
        
        await env.USERS.put(`user:${email}`, JSON.stringify(user));
        
        // 자산에 TL 충전 (assetId가 제공된 경우)
        let asset = null;
        if (assetId) {
          asset = await env.USERS.get(`asset:${assetId}`, 'json');
          if (asset) {
            asset.tlCharged = (asset.tlCharged || 0) + parseInt(amount);
            asset.tlRemaining = asset.tlCharged - (asset.tlConsumed || 0);
            asset.isActive = asset.tlRemaining > 0;
            
            if (asset.isActive && !asset.activatedAt) {
              asset.activatedAt = new Date().toISOString();
              asset.status = '활성화됨 - 수익 창출 가능';
            }
            
            await env.USERS.put(`asset:${assetId}`, JSON.stringify(asset));
          }
        }
        
        // 트랜잭션 기록
        const txId = `tx_${Date.now()}`;
        const transaction = {
          id: txId,
          type: 'charge',
          userId: user.id,
          amount: parseInt(amount),
          balanceBefore: user.tlBalance - parseInt(amount),
          balanceAfter: user.tlBalance,
          assetId,
          timestamp: new Date().toISOString()
        };
        
        await env.USERS.put(`tx:${txId}`, JSON.stringify(transaction));
        
        return Response.json({
          success: true,
          message: `💰 ${amount} TL 충전 완료!`,
          user: {
            email: user.email,
            tlBalance: user.tlBalance
          },
          asset: asset ? {
            id: asset.id,
            title: asset.title,
            tlRemaining: asset.tlRemaining,
            isActive: asset.isActive,
            status: asset.status
          } : null,
          transactionId: txId
        }, { headers: corsHeaders });
        
      } catch (error) {
        return Response.json({
          success: false,
          error: error.message
        }, { status: 500, headers: corsHeaders });
      }
    }
    
    // 5. 사용자 정보 조회
    if (url.pathname === '/api/user' && method === 'GET') {
      const email = url.searchParams.get('email');
      if (!email) {
        return Response.json({ error: '이메일 필요' }, { status: 400, headers: corsHeaders });
      }
      
      const user = await env.USERS.get(`user:${email}`, 'json');
      if (!user) {
        return Response.json({ error: '사용자 없음' }, { status: 404, headers: corsHeaders });
      }
      
      return Response.json({
        success: true,
        user: {
          id: user.id,
          email: user.email,
          username: user.username,
          tlBalance: user.tlBalance,
          assets: user.assets?.length || 0,
          createdAt: user.createdAt
        }
      }, { headers: corsHeaders });
    }
    
    // 404 - API 문서
    return Response.json({
      error: 'API 엔드포인트를 찾을 수 없습니다',
      documentation: {
        title: 'Deconomic API v1',
        description: '잠자는 디지털 파일이 깨어나는 경제',
        endpoints: {
          health: 'GET /health',
          signup: 'POST /api/auth/signup - {email, username}',
          createAsset: 'POST /api/assets - {title, fileType, uploaderEmail}',
          chargeTL: 'POST /api/tl/charge - {email, amount, assetId(optional)}',
          getUser: 'GET /api/user?email={email}'
        },
        tl_types: {
          audio: 'TL3',
          video: 'TL4',
          document: 'TLD',
          image: 'TLI',
          ebook: 'TLE'
        }
      }
    }, { status: 404, headers: corsHeaders });
  }
}
