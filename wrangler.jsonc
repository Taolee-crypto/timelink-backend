{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "timelink-api-worker",
  "main": "src/index.ts",
  "type": "esm",
  "compatibility_date": "2025-12-03",
  "account_id": "a056839cbee168dca5a9439167f98143", // Cloudflare 계정 ID
  "assets": {
    "directory": "./public"
  },
  "kv_namespaces": [
    {
      "binding": "TL_SESSIONS",
      "id": "ea2f9eacaac44899a621dc0315debf01"
    }
  ],
  "observability": {
    "enabled": true
  }
}
