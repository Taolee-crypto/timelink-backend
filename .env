# TimeLink 개발 환경
NODE_ENV=development
PORT=8787
HOST=0.0.0.0

# Cloudflare 설정
CLOUDFLARE_ACCOUNT_ID=a056839cbee168dca5a9439167f98143
DATABASE_ID=cf631397-ed92-4d21-b989-f3b3cedb7ae4
DATABASE_NAME=timelink-db

# JWT 설정
JWT_SECRET=$(openssl rand -hex 32 2>/dev/null || echo "dev-secret-$(date +%s)")
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS 설정
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080
CORS_CREDENTIALS=true

# 로깅
LOG_LEVEL=debug
DEBUG=true

# 파일 업로드
MAX_FILE_SIZE=100MB
ALLOWED_FILE_TYPES=audio/mpeg,audio/wav,audio/flac,audio/aac,video/mp4,video/webm,image/jpeg,image/png,image/gif

# 로컬 개발용 (필요시)
DATABASE_URL=file:./timelink-dev.db
